{
  "name": "x.auto",
  "version": "1.0.7",
  "description": "x.auto streamlines the workflow of auto-service managers by providing an efficient solution for generating work completion documents, managing information about serviced vehicles in a local database, and tracking each employee's activity.",
  "main": "./out/main/index.js",
  "author": "Sam",
  "homepage": "xauto.com",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "cross-env MAIN_VITE_DB_NAME=x.auto.db MAIN_VITE_ENC_KEY=prod MAIN_VITE_ENC_ALG=aes-256-cbc MAIN_VITE_ENC_IV=prod MAIN_VITE_SESS_EXPIRE=15 RENDERER_VITE_CACHING=1 electron-vite dev --watch",
    "build": "cross-env NODE_ENV=production MAIN_VITE_DB_NAME=x.auto.db MAIN_VITE_ENC_KEY=prod MAIN_VITE_ENC_ALG=aes-256-cbc MAIN_VITE_ENC_IV=prod MAIN_VITE_SESS_EXPIRE=15 RENDERER_VITE_CACHING=1 npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "prepare": "husky",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "debug-prod": "node debug-production.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "build": {
    "publish": {
      "provider": "github",
      "owner": "jaspal-creator",
      "repo": "x.auto",
      "private": true
    },
    "win": {
      "target": [
        "portable",
        "nsis",
        "zip"
      ]
    },
    "portable": {
      "artifactName": "x.auto.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^4.36.1",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^3.6.0",
    "electron-log": "^5.3.0",
    "electron-progressbar": "^2.2.1",
    "electron-updater": "^6.1.7",
    "esbuild-plugin-react-virtualized": "^1.0.4",
    "i18next": "^24.2.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.469.0",
    "progressbar": "^1.3.0",
    "react-day-picker": "^8.10.1",
    "react-hook-form": "^7.54.1",
    "react-i18next": "^15.4.0",
    "react-router": "^7.1.1",
    "react-virtualized": "^9.22.5",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^3.7.2",
    "@types/lodash": "^4.17.14",
    "@types/node": "^20.17.19",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-router": "^5.1.20",
    "@types/react-virtualized": "^9.22.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^31.7.6",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^3.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "prettier": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.2",
    "vite": "^6.3.5"
  }
}
